{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/vec-subscribe.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/vec-subscribe", "destination": "/api/vec-subscribe" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ]
}
